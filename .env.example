# Copie este arquivo para .env e ajuste os valores antes de rodar em produção.
# NUNCA comite o arquivo .env real (já está no .gitignore).

ENVIRONMENT=development

# Formato: "chave1:nome_cliente_a,chave2:nome_cliente_b"
# Gere chaves fortes em produção (ex: secrets.token_urlsafe(32)).
API_KEYS_RAW=dev-key-local:cliente_demo

RATE_LIMIT_PER_MINUTE=60

ML_MODEL_DIR=models
ML_MODEL_FILENAME=scam_detector.joblib
ML_VECTORIZER_FILENAME=vectorizer.joblib

ML_CONFIDENCE_THRESHOLD=0.75
RULES_HIGH_RISK_THRESHOLD=0.8

LLM_FALLBACK_ENABLED=true
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

AUDIT_DB_PATH=audit_log.db
